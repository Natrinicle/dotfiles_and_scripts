# Copy to local.env (do not commit) and fill in if you use placeholder-backed aliases.
# Values are examples only.

# Host used by keep_network_up (must be reachable for the health check)
DEFAULT_ROUTE_HOST=gateway.example.home

# NetworkManager connection name (nmcli connection show)
NM_CONNECTION_NAME=Wired connection 1

# Firefox profile directory name under ~/.mozilla/firefox/
FIREFOX_PROFILE=xxxxxxxx.default-release

# Optional company LDAP (if you install examples/ldap.company.example)
# COMPANY_DOMAIN=example.com
# COMPANY_LDAP_HOST=ldap.example.com
# LDAP_USERS_OU=People
# LDAP_BASE_DN=dc=example,dc=com
